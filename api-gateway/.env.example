# ─── 共享配置（与 wiki-app 保持一致）────────────────────────
# wiki/ 目录的路径，相对于 api-gateway/ 目录
WIKI_PATH=../wiki

# LLM 提供商：moonshot 或 qwen
LLM_PROVIDER=moonshot
MOONSHOT_API_KEY=your_moonshot_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# 知识库加载字符上限
MAX_WIKI_CHARS=80000
MAX_CHAT_WIKI_CHARS=40000

# ─── Gateway 专属配置 ────────────────────────────────────────
# Gateway 数据库路径（独立于 wiki-app 的 data.db）
GW_DB_PATH=./gateway.db

# 管理员主密钥（保护 App/Key 管理接口），请使用随机字符串
GATEWAY_ADMIN_KEY=your_very_secret_admin_key_here

# 全局默认限流（次/分钟），可在每个 App 级别单独配置
DEFAULT_RATE_LIMIT=60

# ─── 开发调试万能密钥（可选）────────────────────────────────
# 设置后，使用该 Key 可绕过数据库注册，直接获得全部权限，不限速。
# 适合本地联调多个应用时使用，无需为每个应用单独注册 API Key。
# 生产环境：删除此行或留空，该功能自动关闭。
# DEV_API_KEY=dev-only-key-change-or-remove-in-production
