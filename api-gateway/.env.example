# ─── 共享配置（与 wiki-app 保持一致）────────────────────────
# wiki/ 目录的路径，相对于 api-gateway/ 目录
WIKI_PATH=../wiki

# LLM 提供商：moonshot 或 qwen
LLM_PROVIDER=moonshot
MOONSHOT_API_KEY=your_moonshot_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# 知识库加载字符上限
MAX_WIKI_CHARS=80000
MAX_CHAT_WIKI_CHARS=40000

# ─── Gateway 专属配置 ────────────────────────────────────────
# Gateway 数据库路径（独立于 wiki-app 的 data.db）
GW_DB_PATH=./gateway.db

# 管理员主密钥（保护 App/Key 管理接口），请使用随机字符串
GATEWAY_ADMIN_KEY=your_very_secret_admin_key_here

# 全局默认限流（次/分钟），可在每个 App 级别单独配置
DEFAULT_RATE_LIMIT=60

# ─── 领域定制（可选）────────────────────────────────────────
# 每次查询必加载的 wiki 子目录，逗号分隔（留空则不强制加载）
# 示例：WIKI_ALWAYS_LOAD=modules,proposal-stages
WIKI_ALWAYS_LOAD=

# 自定义 query prompt 文件路径（留空则自动查找 wiki-app/prompts/query_prompt.md）
# WIKI_QUERY_PROMPT_FILE=/path/to/your/query_prompt.md

# 向 /v1/wiki/options 追加自定义选项组（JSON 格式）
# 示例：WIKI_EXTRA_OPTIONS={"project_types":["新建","改造升级","咨询规划","运营维护"]}
WIKI_EXTRA_OPTIONS=

# ─── 开发调试万能密钥（可选）────────────────────────────────
# 设置后，使用该 Key 可绕过数据库注册，直接获得全部权限，不限速。
# 适合本地联调多个应用时使用，无需为每个应用单独注册 API Key。
# 生产环境：删除此行或留空，该功能自动关闭。
# DEV_API_KEY=dev-only-key-change-or-remove-in-production

# ─── CORS 配置 ───────────────────────────────────────────────
# 逗号分隔的允许来源，留空则允许所有来源（生产环境建议显式配置）
# 示例：CORS_ORIGINS=https://ai-app.company.com,http://192.168.1.200:3000
CORS_ORIGINS=

# ─── Schema 目录 ─────────────────────────────────────────────
SCHEMA_DIR=../schema
