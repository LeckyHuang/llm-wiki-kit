# LLM 提供商：moonshot 或 qwen
LLM_PROVIDER=moonshot

# Moonshot API Key（使用 moonshot 时填写）
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 通义千问 API Key（使用 qwen 时填写）
QWEN_API_KEY=your_qwen_api_key_here

# Wiki 文件目录（绝对路径或相对路径）
WIKI_PATH=./wiki

# Wiki 最大加载字符数（默认 80000，约 80k 字符）
MAX_WIKI_CHARS=80000

# 原始方案文件目录（存放 PPT/PDF 供用户下载）
SOURCE_FILES_DIR=./source-files

# 概算模板文件目录
ESTIMATION_FILES_DIR=./estimation-files

# Prompt 模板目录（存放 query_prompt.md）
PROMPTS_DIR=./prompts

# SQLite 数据库路径
DB_PATH=./data.db

# JWT 签名密钥（请务必设置一个随机字符串，重启后若未设置将自动生成并写入本文件）
# 生成方法：python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
